# wikipath environment configuration (example)
# Copy to .env and fill in your own values. Never commit .env.

# Kyma API gateway key — required for the LLM enrichment scripts only.
# Get one at https://api.kymaapi.com/
KYMA_API_KEY=sk-your-key-here

# Override the default LLM model. Defaults to deepseek-v3 (stable tier).
# Bench other Kyma models with: python3 scripts/bench_models.py
# LLM_MODEL=deepseek-v4-pro

# Admin bearer token for /api/admin/popularity. Required only if you
# expose that endpoint; generate a random string and keep it secret.
# ADMIN_TOKEN=change-me-to-a-random-string
